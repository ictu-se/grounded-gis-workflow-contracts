    "required_fields": [
      "tract_id",
      "temp_mean__mean",
      "temp_mean__count",
      "flood_area_m2"
    ]
  },
  "validation": {
    "crs": [],
    "schema": [],
    "geometry": [],
    "raster": [],
    "map_quality": []
  },
  "rationale": "Perform zonal statistics on census_tracts and temperature_raster to get mean temperature, count of schools within tracts, and flood area per tract."
}