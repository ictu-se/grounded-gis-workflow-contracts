{
  "task_id": "T015",
  "operation": "point_count_join",
  "inputs": {
    "target": "census_tracts",
    "join": [
      "hospital_points",
      "school_points"
    ]
  },
  "params": {
    "target_epsg": 4269,
    "group_field": "tract_id",
    "count_field": "count(school_id)",
    "predicate": "ST_Intersects(school_points.geometry, census_tracts.geometry)"
  },
  "output": {
    "filename": "T015_school_hospital_counts.gpkg",
    "type": "vector",
    "required_fields": [
      "tract_id",
      "school_count"
    ]
  },
  "validation": {
    "crs": [],
    "schema": [
      {
        "name": "tract_id",
        "type": "string"
      },
      {
        "name": "school_count",
        "type": "integer"
      }
    ],
    "geometry": [],
    "raster": [],
    "map_quality": []
  },
  "rationale": "First, join census_tracts with school_points to count the number of schools in each tract. Then, join the result with hospital_points to get the total number of hospitals within each tract."
}