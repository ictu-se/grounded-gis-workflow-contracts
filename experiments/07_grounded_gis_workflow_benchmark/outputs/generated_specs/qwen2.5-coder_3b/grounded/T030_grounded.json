{
  "task_id": "T030",
  "operation": "choropleth_export",
  "inputs": {
    "layer": "zonal_input_for_map"
  },
  "params": {
    "field": [
      "temp_mean",
      "sfha_tf",
      "school_count"
    ],
    "classes": [
      {
        "min": -10,
        "max": 25,
        "label": "Low"
      },
      {
        "min": 26,
        "max": 40,
        "label": "Moderate"
      },
      {
        "min": 41,
        "max": 55,
        "label": "High"
      }
    ],
    "scheme": "Quantiles",
    "cmap": "YlGnBu",
    "title": "Combined Heat, Flood Exposure, and School Availability Risk",
    "legend_title": "Risk Level",
    "source_note": "Data sourced from various GIS files."
  },
  "output": {
    "filename": "T030_multivariate_risk_map.png",
    "type": "png",
    "required_fields": []
  },
  "validation": {
    "crs": [
      "EPSG:4269"
    ],
    "schema": [],
    "geometry": [],
    "raster": [],
    "map_quality": [
      "High"
    ]
  },
  "rationale": "This choropleth map uses temperature mean, flood exposure (SFHA TF), and school count as risk indicators. The Quantiles scheme divides the data into three classes to visually represent different levels of risk."
