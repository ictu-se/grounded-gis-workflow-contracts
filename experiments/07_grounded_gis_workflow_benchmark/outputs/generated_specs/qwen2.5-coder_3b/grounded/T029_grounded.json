{
  "task_id": "T029",
  "operation": "choropleth_export",
  "inputs": {
    "layer": "census_tracts"
  },
  "params": {
    "field": "hospital_count",
    "classes": [
      "<1",
      "1-5",
      "6-10",
      "11-20",
      ">20"
    ],
    "scheme": "Quantile",
    "cmap": "viridis",
    "title": "Hospital Access by Census Tract",
    "legend_title": "Number of Hospitals",
    "source_note": "Data from hospital_points.gpkg"
  },
  "output": {
    "filename": "T029_hospital_access_choropleth.png",
    "type": "png",
    "required_fields": []
  },
  "validation": {
    "crs": [
      "EPSG:4326"
    ],
    "schema": [],
    "geometry": [],
    "raster": [],
    "map_quality": [
      "high"
    ]
  },
  "rationale": "This operation creates a choropleth map of hospital access by census tract, using the number of hospitals as the data field."
}