{
  "task_id": "T023",
  "operation": "zonal_statistics",
  "inputs": {
    "tracts": "path/to/tracts.shp",
    "temperature_data": "path/to/temperature_data.tif"
  },
  "params": {
    "statistic_type": "mean",
    "quartile": "top_25"
  },
  "output": {
    "filename": "T023_temperature_stats_hot_tracts.gpkg",
    "type": "vector",
    "required_fields": [
      "tract_id",
      "temp_mean",
      "temp_sum"
    ]
  },
  "validation": {
    "crs": [
      "EPSG:4326"
    ],
    "schema": [
      {
        "field_name": "tract_id",
        "data_type": "integer"
      },
      {
        "field_name": "temp_mean",
        "data_type": "float"
      },
      {
        "field_name": "temp_sum",
        "data_type": "float"
      }
    ],
    "geometry": [],
    "raster": [],
    "map_quality": []
  },
  "rationale": "Compute the mean temperature for each tract and retain only those with the highest mean temperature, saving the result as a GeoPackage."
}