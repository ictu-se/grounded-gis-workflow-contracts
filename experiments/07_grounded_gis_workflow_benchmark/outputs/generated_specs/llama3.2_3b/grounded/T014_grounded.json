{
  "task_id": "T014",
  "operation": "point_count_join",
  "inputs": {
    "target": "census_tracts.gpkg",
    "join": "school_points.gpkg"
  },
  "params": {
    "target_epsg": 4326,
    "group_field": "tract_id",
    "count_field": "school_count",
    "predicate": "COUNT(school_id) > 0"
  },
  "output": {
    "filename": "T014_tracts_with_schools.gpkg",
    "type": "vector",
    "required_fields": [
      "tract_id",
      "school_count"
    ]
  }
}