{
  "task_id": "T024",
  "operation": "zonal_statistics",
  "inputs": {
    "temperature_layer": "path_to_temperature_layer.gpkg",
    "school_layer": "path_to_school_layer.gpkg"
  },
  "params": {
    "statistics_type": "mean",
    "zone_field": "tract_id",
    "value_field": "temperature"
  },
  "output": {
    "filename": "T024_temperature_school_join.gpkg",
    "type": "vector",
    "required_fields": [
      "tract_id",
      "temp_mean",
      "school_count"
    ]
  },
  "validation": {
    "crs": [
      "EPSG:4326"
    ],
    "schema": [
      {
        "name": "tract_id",
        "type": "integer"
      },
      {
        "name": "temp_mean",
        "type": "real"
      },
      {
        "name": "school_count",
        "type": "integer"
      }
    ],
    "geometry": [
      "Polygon"
    ]
  },
  "rationale": "Compute mean temperature and count schools within each tract, then join the results into a new vector layer."
}