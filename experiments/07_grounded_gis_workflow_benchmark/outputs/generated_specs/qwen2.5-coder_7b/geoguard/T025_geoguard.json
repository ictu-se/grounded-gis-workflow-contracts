    "raster": "temperature_raster.tif"
  },
  "params": {
    "stats": [
      "mean"
    ],
    "column_prefix": "temp_",
    "align_polygons_to_raster_crs": true
  },
  "output": {
    "filename": "T025_temperature_flood_school.gpkg",
    "type": "vector",
    "required_fields": [
      "tract_id",
      "temp_mean"
    ]
  },
  "validation": {
    "crs": [
      "EPSG:4326"
    ],
    "schema": [
      "tract_id",
      "temp_mean"
    ],
    "geometry": [],
    "raster": [],
    "map_quality": []
  },
  "rationale": "Calculate mean temperature for each census tract and save the result in a new GeoPackage file."
}