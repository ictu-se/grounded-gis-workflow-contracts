{
  "task_id": "T029",
  "operation": "point_count_join",
  "inputs": {
    "target": "census_tracts.gpkg",
    "join": "hospital_points.gpkg"
  },
  "params": {
    "target_epsg": 4326,
    "group_field": "tract_id",
    "count_field": "hospital_count",
    "predicate": "intersects"
  },
  "output": {
    "filename": "census_tracts_with_hospitals.gpkg",
    "type": "vector",
    "required_fields": [
      "tract_id",
      "hospital_count"
    ]
  },
  "validation": {
    "crs": [
      "EPSG:4326"
    ],
    "schema": [],
    "geometry": [
      "buffer(0)"
    ],
    "raster": [],
    "map_quality": []
  },
  "rationale": "Join hospital points to census tracts to count hospitals per tract."
}