{
  "task_id": "T012",
  "operation": "point_count_join",
  "inputs": {
    "target": "census_tracts.gpkg",
    "join": "hospital_points.gpkg"
  },
  "params": {
    "target_epsg": 4326,
    "group_field": "tract_id",
    "count_field": "hospital_count",
    "predicate": "within"
  },
  "output": {
    "filename": "T012_hospital_count_by_tract.gpkg",
    "type": "vector",
    "required_fields": [
      "tract_id",
      "hospital_count"
    ]
  },
  "validation": {
    "crs": [
      4326
    ],
    "schema": [
      "tract_id",
      "hospital_count"
    ],
    "geometry": [
      "buffer(0) if invalid"
    ],
    "raster": [],
    "map_quality": []
  },
  "rationale": "Count hospitals inside each census tract and save the tract polygons with hospital_count as T012_hospital_count_by_tract.gpkg."
}