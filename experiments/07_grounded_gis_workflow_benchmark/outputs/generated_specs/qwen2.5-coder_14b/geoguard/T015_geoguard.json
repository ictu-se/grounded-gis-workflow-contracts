{
  "task_id": "T015",
  "operation": "point_count_join",
  "inputs": {
    "target": "census_tracts.gpkg",
    "join": [
      "school_points.gpkg",
      "hospital_points.gpkg"
    ]
  },
  "params": {
    "target_epsg": 4326,
    "group_field": "tract_id",
    "count_field": [
      "school_count",
      "hospital_count"
    ],
    "predicate": "intersects"
  },
  "output": {
    "filename": "T015_school_hospital_counts.gpkg",
    "type": "vector",
    "required_fields": [
      "tract_id",
      "school_count",
      "hospital_count"
    ]
  },
  "validation": {
    "crs": [
      4326
    ],
    "schema": [
      "tract_id",
      "school_count",
      "hospital_count"
    ],
    "geometry": [
      "buffer(0) if invalid"
    ],
    "raster": [],
    "map_quality": []
  },
  "rationale": "Join school and hospital points to census tracts to count the number of schools and hospitals within each tract."
}