{
  "task_id": "T024",
  "operation": "zonal_statistics",
  "inputs": {
    "polygons": "census_tracts",
    "raster": "temperature_raster"
  },
  "params": {
    "stats": [
      "mean"
    ],
    "column_prefix": "temp_",
    "align_polygons_to_raster_crs": true
  },
  "output": {
    "filename": "T024_temperature.gpkg",
    "type": "vector"
  },
  "validation": {
    "crs": [
      "EPSG:4326"
    ],
    "fields": [
      "tract_id"
    ]
  },
  "rationale": "Calculate mean temperature for each tract using zonal statistics."
}